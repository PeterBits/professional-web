# ============================================================================
# Google Calendar — integración via Service Account (server-side)
# ============================================================================
# Pasos para obtener estos valores:
#   1. console.cloud.google.com → crear proyecto (o reusar uno)
#   2. APIs & Services → Library → habilitar "Google Calendar API"
#   3. IAM & Admin → Service Accounts → Create Service Account
#   4. En la cuenta creada → Keys → Add Key → Create new key → JSON
#   5. Abre el JSON: copia "client_email" en GOOGLE_SERVICE_ACCOUNT_EMAIL
#      y "private_key" en GOOGLE_PRIVATE_KEY (con los \n literales).
#   6. En calendar.google.com → tu calendario → Settings → Share with specific
#      people → añade el client_email con permiso "See all event details".
#   7. En la misma página copia el "Calendar ID" en GOOGLE_CALENDAR_ID.

GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================================================
# WhatsApp
# ============================================================================
# Numero en formato internacional, sin "+" ni espacios (ej: 34722185903)
PUBLIC_WHATSAPP_NUMBER=34722185903
