---
const DEFAULT_WHATSAPP_NUMBER = '34722185903';
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? DEFAULT_WHATSAPP_NUMBER;
const whatsappHref = `https://wa.me/${whatsappNumber}`;
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__tagline title-sm">Rodando Libre</p>
    <div class="footer__links">
      <a href={whatsappHref} class="footer__link" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        <img src="/icons/whatsapp.svg" alt="WhatsApp" class="footer__icon-img" />
      </a>
      <a href="https://instagram.com/rodandolibre" class="footer__link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <img src="/icons/instagram.svg" alt="Instagram" class="footer__icon-img" />
      </a>
    </div>
    <p class="footer__copy label-sm">© 2026 Rodando Libre. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface-container-low);
    padding: 3rem 2rem;
  }
  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .footer__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--on-surface);
    font-size: 1.125rem;
  }
  .footer__links { display: flex; gap: 1.25rem; }
  .footer__link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--on-surface-variant);
    font-weight: 500;
    font-size: 0.875rem;
    transition: color var(--transition);
  }
  .footer__link:hover { color: var(--primary); }
  .footer__link:hover img { filter: brightness(1.2); }
  .footer__icon-img { width: 2.25rem; height: 2.25rem; transition: filter var(--transition); }
  .footer__copy { color: var(--outline); }

  @media (max-width: 767px) {
    .footer__links { justify-content: center; }
  }

  @media (min-width: 768px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
