---
import { Picture } from 'astro:assets';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import vanData from '../data/van-data.json';
import interiorFrontImg from '../assets/gallery-interior-front.png';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const ICONS: Record<string, string> = {
  bed:    '<path d="M3 18v-6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6M3 18h18M3 18v2M21 18v2M7 10V7a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v3"/>',
  stove:  '<rect x="4" y="4" width="16" height="16" rx="2"/><circle cx="9" cy="10" r="1.5"/><circle cx="15" cy="10" r="1.5"/><path d="M7 17h10"/>',
  heat:   '<path d="M12 3c1 2 3 3 3 6a3 3 0 0 1-6 0c0-3 2-4 3-6z"/><path d="M6 14c1 1 2 2 2 4a2 2 0 1 1-4 0c0-2 1-3 2-4z"/><path d="M18 14c1 1 2 2 2 4a2 2 0 1 1-4 0c0-2 1-3 2-4z"/>',
  solar:  '<rect x="3" y="5" width="18" height="10" rx="1"/><path d="M3 10h18M8 5v10M13 5v10"/><path d="M7 20h10"/>',
  awning: '<path d="M3 7h18l-2 10H5z"/><path d="M5 17v3"/><path d="M19 17v3"/>',
  camera: '<rect x="3" y="7" width="18" height="12" rx="2"/><circle cx="12" cy="13" r="3.5"/><path d="M7 7l2-2h6l2 2"/>',
  kit:    '<path d="M3 12h18"/><path d="M5 12a7 7 0 0 0 14 0"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="8" y1="22" x2="16" y2="22"/>',
  doors:  '<path d="M6 3h8a2 2 0 0 1 2 2v16H6V3z"/><circle cx="13" cy="13" r="1"/>'
};

const specs = vanData.specs;
const equipment = vanData.equipment;
---

<section class="van section">
  <div class="van__inner">
    <div class="van__media">
      <Picture
        src={interiorFrontImg}
        formats={['avif', 'webp']}
        widths={[400, 800, 1200]}
        sizes="(max-width: 1023px) 100vw, (max-width: 1199px) 50vw, 600px"
        alt={t.home.info.imageAlt}
        class="van__img"
        loading="lazy"
      />
      <div class="van__scrim"></div>
      <div class="van__overlay">
        <span class="label-md van__label">{t.home.info.label}</span>
        <h2 class="display-md van__title">{t.home.info.title}</h2>
      </div>
    </div>

    <div class="van__content">
      <div class="van__block">
        <h3 class="title-lg">{t.home.info.specsTitle}</h3>
        <dl class="van__specs">
          {specs.map((s) => (
            <div class="van__spec">
              <dt class="label-sm">{s.label[lang]}</dt>
              <dd class="title-sm">{s.value[lang]}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="van__block">
        <h3 class="title-lg">{t.home.info.equipmentTitle}</h3>
        <ul class="van__equipment">
          {equipment.map((item) => (
            <li class="van__item">
              <span class="van__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[item.icon] ?? ''} />
              </span>
              <span class="body-lg">{item.label[lang]}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .van { background: var(--surface); }
  .van__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .van__media {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }
  .van__media picture { display: contents; }
  .van__img { width: 100%; height: 100%; object-fit: cover; }
  .van__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, var(--surface) 100%);
  }
  .van__overlay {
    position: absolute;
    left: 2rem;
    right: 2rem;
    bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .van__label { color: var(--tertiary); }
  .van__title { color: var(--on-surface); max-width: 14ch; }

  .van__content { display: flex; flex-direction: column; gap: 3rem; }
  .van__block { display: flex; flex-direction: column; gap: 1.25rem; }

  .van__specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem 2rem;
    margin: 0;
  }
  .van__spec { display: flex; flex-direction: column; gap: 0.25rem; }
  .van__spec dt { color: var(--on-surface-variant); }
  .van__spec dd { margin: 0; color: var(--on-surface); }

  .van__equipment {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 1.5rem;
  }
  .van__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--on-surface);
  }
  .van__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-sm);
    background: var(--surface-container);
    color: var(--primary);
  }

  @media (min-width: 1024px) {
    .van__inner {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    .van__media { aspect-ratio: 3/4; position: sticky; top: calc(var(--header-height) + 2rem); }
  }
</style>
