---
import '../styles/booking-calendar.css';

const DEFAULT_WHATSAPP_NUMBER = '34111223344';
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? DEFAULT_WHATSAPP_NUMBER;
const whatsappHref = `https://wa.me/${whatsappNumber}`;

const monthsJson = JSON.stringify([
  'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
  'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre',
]);

const i18nJson = JSON.stringify({
  selectionCountSingular: '1 día seleccionado',
  selectionCountPlural: '%n días seleccionados',
  selectionClear: 'Limpiar selección',
  modalTitle: 'Confirma tu reserva',
  modalDatesLabel: 'Días seleccionados',
  modalTotalLabel: 'Total estimado',
  modalCancel: 'Cancelar',
  modalConfirm: 'Confirmar',
});

const weekdays = ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'];
---

<section class="cal section">
  <div class="cal__inner">
    <header class="cal__head">
      <h2 class="display-sm">Disponibilidad</h2>
      <ul class="cal__legend">
        <li class="cal__legend-item">
          <span class="cal__swatch cal__swatch--available"><span class="cal__swatch-num">18</span></span>
          Disponible
        </li>
        <li class="cal__legend-item">
          <span class="cal__swatch cal__swatch--reserved"><span class="cal__swatch-num">18</span></span>
          Reservado
        </li>
        <li class="cal__legend-item">
          <span class="cal__swatch cal__swatch--unavailable"><span class="cal__swatch-num">18</span></span>
          No disponible
        </li>
      </ul>
    </header>

    <div
      class="cal__frame"
      id="cal-frame"
      data-months={monthsJson}
      data-whatsapp={whatsappHref}
      data-i18n={i18nJson}
    >
      <div class="cal__nav">
        <span id="cal-label" class="title-lg"></span>
        <div class="cal__nav-btns">
          <button id="cal-prev" class="cal__nav-btn" type="button" aria-label="Previous month">&lsaquo;</button>
          <button id="cal-next" class="cal__nav-btn" type="button" aria-label="Next month">&rsaquo;</button>
        </div>
      </div>

      <div id="cal-grid" class="cal__grid">
        {weekdays.map((d) => (
          <div class="cal__weekday label-sm">{d}</div>
        ))}
      </div>

      <p id="cal-loading" class="cal__status">Cargando disponibilidad…</p>
      <div id="cal-error" class="cal__error" hidden>
        <p>No se pudo cargar la disponibilidad.</p>
        <p class="label-sm">Escríbenos por WhatsApp y te confirmamos al instante.</p>
      </div>
    </div>

    <div id="cal-selection-bar" class="cal__selection-bar" hidden>
      <span id="cal-selection-count" class="cal__selection-count"></span>
      <button id="cal-selection-clear" class="btn btn--secondary cal__selection-clear-btn" type="button"></button>
    </div>

    <div class="cal__cta">
      <button id="cal-whatsapp-btn" class="btn btn--primary" type="button">
        Reservar por WhatsApp
      </button>
    </div>
  </div>
</section>

<dialog id="cal-modal" class="cal__modal">
  <div class="cal__modal-content">
    <h3 id="cal-modal-title" class="cal__modal-title"></h3>
    <div class="cal__modal-body">
      <p id="cal-modal-dates-label" class="cal__modal-dates-label"></p>
      <ul id="cal-modal-dates-list" class="cal__modal-dates-list"></ul>
      <p id="cal-modal-total" class="cal__modal-total" hidden></p>
    </div>
    <div class="cal__modal-actions">
      <button id="cal-modal-cancel" class="btn btn--secondary" type="button"></button>
      <button id="cal-modal-confirm" class="btn btn--primary" type="button"></button>
    </div>
  </div>
</dialog>

<script>
  import '../scripts/bookingCalendar';
</script>
