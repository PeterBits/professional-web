---
import { Picture } from 'astro:assets';
import galleryExterior from '../assets/gallery-exterior.png';
import galleryInteriorBack from '../assets/gallery-interior-back.png';
import galleryDining from '../assets/gallery-dining.png';
import galleryFridge from '../assets/gallery-fridge.png';

const GALLERY_IMAGES = [
  { src: galleryExterior,     alt: 'Vista lateral de la camper en un prado verde' },
  { src: galleryInteriorBack, alt: 'Cocina y acceso a la zona trasera' },
  { src: galleryDining,       alt: 'Comedor con mesa central y bancos' },
  { src: galleryFridge,       alt: 'Nevera abierta llena de provisiones' },
];
---

<section class="gallery section">
  <div class="gallery__inner">
    <header class="gallery__header">
      <span class="label-md gallery__label">Galería</span>
      <h2 class="display-md">La camper, por dentro y por fuera.</h2>
    </header>
    <div class="gallery__grid">
      {GALLERY_IMAGES.map(({ src, alt }) => (
        <figure class="gallery__item">
          <Picture
            src={src}
            formats={['avif', 'webp']}
            widths={[400, 800, 1200]}
            sizes="(max-width: 767px) 100vw, (max-width: 1199px) 50vw, 600px"
            alt={alt}
            class="gallery__img"
            loading="lazy"
          />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery { background: var(--surface); }

  .gallery__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .gallery__header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 42ch;
  }

  .gallery__label { color: var(--tertiary); }

  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .gallery__item {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    aspect-ratio: 4 / 3;
  }

  .gallery__item picture {
    display: contents;
  }
  .gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .gallery__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }
</style>
