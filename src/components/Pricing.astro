---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import vanData from '../data/van-data.json';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const pricingSubtitle = vanData.pricing.subtitle[lang];
const availabilityLabel = vanData.pricing.availabilityLabel[lang];
const seasons = vanData.pricing.seasons;
---

<section class="pricing section">
  <div class="pricing__inner">
    <header class="pricing__header">
      <span class="label-md pricing__label">{t.home.pricing.label}</span>
      <h2 class="display-md">{t.home.pricing.title}</h2>
      <p class="body-lg pricing__subtitle">{pricingSubtitle}</p>
    </header>

    <ul class="pricing__grid">
      {seasons.map((card) => (
        <li class="pricing__card">
          <p class="label-md pricing__season">{card.season[lang]}</p>
          <p class="pricing__price">
            <span class="pricing__amount display-md">{availabilityLabel}</span>
          </p>
          <p class="body-lg pricing__months">{card.months[lang]}</p>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .pricing { background: var(--surface-container-lowest); }
  .pricing__inner { max-width: 1200px; margin: 0 auto; }
  .pricing__header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 48rem;
    margin-bottom: 3rem;
  }
  .pricing__label { color: var(--tertiary); }
  .pricing__subtitle { color: var(--on-surface-variant); }

  .pricing__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .pricing__card {
    background: var(--surface-container);
    border-radius: var(--radius-lg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform var(--transition), background var(--transition);
  }
  .pricing__card:hover {
    transform: translateY(-4px);
    background: var(--surface-container-high);
  }
  .pricing__season { color: var(--tertiary); }
  .pricing__price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0;
  }
  .pricing__amount {
    color: var(--on-surface);
    font-size: 1.75rem;
  }
  .pricing__months { color: var(--on-surface-variant); }
  .pricing__note {
    margin-top: 2.5rem;
    color: var(--on-surface-variant);
    text-align: center;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .pricing__grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  }
</style>
