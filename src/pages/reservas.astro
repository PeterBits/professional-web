---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingCalendar from '../components/BookingCalendar.astro';
import ContactBlock from '../components/ContactBlock.astro';

const SITE = 'https://rodandolibre.es';
---

<BaseLayout
  title="Reservar camper en Zamora | Rodando Libre"
  description="Consulta disponibilidad y reserva tu camper en Zamora. Escapadas desde tu ciudad."
  active="bookings"
  canonicalUrl={`${SITE}/reservas`}
>
  <Header slot="header" active="bookings" />
  <BookingCalendar />
  <ContactBlock />
  <Footer slot="footer" />
</BaseLayout>
